# HASH Miner — Multi-Wallet Multi-GPU Config
# ============================================

# RPC endpoint
RPC_URL=https://ethereum-rpc.publicnode.com

# --- Wallets ---
# Option A: Multiple wallets (auto-assigns GPU per wallet)
PRIVATE_KEY_1=0xYOUR_FIRST_WALLET_KEY
PRIVATE_KEY_2=0xYOUR_SECOND_WALLET_KEY
# PRIVATE_KEY_3=0x...
# PRIVATE_KEY_4=0x...

# Option B: Single wallet (uses all GPUs)
# PRIVATE_KEY=0xYOUR_SINGLE_WALLET_KEY

# --- GPU ---
GPU=1
# GPU_BATCH=4194304        # nonces per dispatch per GPU (default: 4M)

# --- CPU fallback ---
MINER_THREADS=8

# --- Gas ---
PRIORITY_GWEI=20
MAX_FEE_GWEI=40
# GAS_LIMIT_OVERRIDE=200000
