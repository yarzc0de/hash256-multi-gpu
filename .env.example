# Template config — aman di-commit. Copy ke .env, isi nilai asli.

PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY_HERE
RPC_URL=https://eth.llamarpc.com
MINER_THREADS=8

# GPU Mining (Multi-GPU support)
GPU=1
# GPU_BATCH=4194304        # nonces per dispatch per GPU (default: 4M)
# GPU_INDEX=0              # optional: use only this GPU index (omit = ALL GPUs)

# Gas tuning
# PRIORITY_GWEI=5
# MAX_FEE_GWEI=100
# GAS_LIMIT_OVERRIDE=200000
